# ╔══════════════════════════════════════════════════════════════════════╗
# ║  KnowledgeHub AI — Docker Environment Variables                     ║
# ║  Copy this file to .env and edit as needed:                         ║
# ║    cp .env.docker .env                                              ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pass
POSTGRES_DB=knowledgehub

# ── Port Mapping ─────────────────────────────────────────────────────
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=80

# ── Auth / JWT ───────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── LLM Provider: "ollama" or "huggingface" ──────────────────────────
LLM_PROVIDER=ollama

# ── Ollama (used when LLM_PROVIDER=ollama) ───────────────────────────
# host.docker.internal lets the container reach Ollama on the host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# ── HuggingFace (used when LLM_PROVIDER=huggingface) ─────────────────
HF_API_KEY=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# HF_INFERENCE_ENDPOINT=

# ── RAG Pipeline Tuning ──────────────────────────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
CHUNK_METADATA_LENGTH=1000
RETRIEVAL_TOP_K=8
MAX_NEW_TOKENS=1024
LLM_TEMPERATURE=0.3
SUMMARY_SNIPPET_LENGTH=3000
HISTORY_MESSAGE_LIMIT=10
POSTGRES_PASSWORD=your_password
SECRET_KEY=some-secret-value
