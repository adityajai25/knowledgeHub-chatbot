# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowledgehub"

# ── Auth / JWT ───────────────────────────────────────────────────────
SECRET_KEY="change-me-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── LLM Provider: "ollama" or "huggingface" ──────────────────────────
LLM_PROVIDER="ollama"

# ── Ollama (used when LLM_PROVIDER=ollama) ───────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_TIMEOUT=120

# ── HuggingFace (used when LLM_PROVIDER=huggingface) ─────────────────
HF_API_KEY="your-huggingface-api-key"
HF_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
HF_GENERATION_MODEL="mistralai/Mistral-7B-Instruct-v0.3"
# HF_INFERENCE_ENDPOINT=

# ── RAG Pipeline Tuning ──────────────────────────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
CHUNK_METADATA_LENGTH=1000
RETRIEVAL_TOP_K=8
MAX_NEW_TOKENS=1024
LLM_TEMPERATURE=0.3
SUMMARY_SNIPPET_LENGTH=3000
HISTORY_MESSAGE_LIMIT=10
